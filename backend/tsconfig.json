{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",

    "moduleResolution": "node",

    "types": ["node"],

    "lib": ["ES2020"],

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": false,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,

    "resolveJsonModule": true,

    "sourceMap": true
  },

  "include": [
    "src/**/*"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}